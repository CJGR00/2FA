PORT=3000
NODE_ENV=development

# 32-byte hexadecimal key for AES-256-GCM encryption of TOTP secrets.
ENCRYPTION_KEY=super_secure_random_key_for_aes_256_gcm_encryption_here

# Session Timeout (in minutes)
SESSION_TIMEOUT_MINUTES=30

# Rate Limiting & Lockouts
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=15

# Resend verification code cooldown (in seconds)
RESEND_COOLDOWN_SECONDS=30

# Code Expiration (in minutes)
CODE_EXPIRATION_MINUTES=5

# SMS Delivery (Twilio) - Optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email Delivery (Gmail SMTP)
# To use Gmail, you must generate an "App Password" from your Google Account settings.
GMAIL_USER=
GMAIL_APP_PASSWORD=
